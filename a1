    }

    if (q3 === "2") {
      tips.push("感情が先に動くのは自然なことです。驚いた話題ほど、シェアや判断の前に『日付』『出典』『他媒体の扱い』の3点だけ確認すると安心です。");
    } else {
      tips.push("事実確認をしようとする姿勢が大きな強みです。確認に時間をかけすぎて疲れたら、『この件は今は保留』と決めるのも大事です。");
    }

    if (q4 === "1") {
      tips.push("情報を人に届ける力があります。シェア前に短く一言『出典はここ』『まだ速報段階』のような注釈を添えると、さらに信頼されやすくなります。");
    } else {
      tips.push("自分の中で消化できる落ち着きがあります。たまに『これは誰かに共有する価値があるか』と考えると、良い情報の循環が生まれます。");
    }

    if (q5 === "2") {
      tips.push("信頼できる情報源を持つのは強みです。ただし、重要なテーマほど1つだけに頼らず、違う角度の説明を1本だけ足すと判断の偏りを減らせます。");
    } else {
      tips.push("比較しながら考える姿勢がとても健全です。毎回すべてを見比べるのは大変なので、『重い話題だけ複数確認』など自分ルールを作ると続けやすいです。");
    }

    return tips;
  }

  function getArticleData() {
    const q1 = getAnswerValue(0);
    const q2 = getAnswerValue(1);
    const q3 = getAnswerValue(2);
    const q5 = getAnswerValue(4);

    if (q3 === "2") return ARTICLE_BY_CATEGORY.emotional;
    if (q2 === "2") return ARTICLE_BY_CATEGORY.focused;
    if (q1 === "2") return ARTICLE_BY_CATEGORY.social;
    if (q5 === "1") return ARTICLE_BY_CATEGORY.balanced;

    return ARTICLE_BY_CATEGORY.balanced;
  }

  function getShareText(result) {
    return `ニュース接触タイプ診断の結果は「${result.name}」でした！\n${result.description}\n#ニュース接触タイプ診断`;
  }

  function renderCurrentQuestion() {
    resultArea.classList.add("hidden");
    quizDiv.innerHTML = "";

    if (currentQuestionIndex >= QUESTIONS.length) {
      showResult();
      return;
    }

    const q = QUESTIONS[currentQuestionIndex];
    const answeredCount = currentQuestionIndex;
    const progressPercent = (answeredCount / QUESTIONS.length) * 100;

    const panel = document.createElement("div");
    panel.className = "panel";

    const progressWrap = document.createElement("div");
    progressWrap.className = "progress-wrap";
    progressWrap.innerHTML = `
      <div class="progress-top">
        <span>進捗</span>
        <span>${currentQuestionIndex + 1} / ${QUESTIONS.length}</span>
      </div>
      <div class="progress-bar" aria-hidden="true">
        <div class="progress-fill" style="width: ${progressPercent}%;"></div>
      </div>
    `;

    const title = document.createElement("div");
    title.className = "q-title";
    title.textContent = q.text;

    const answers = document.createElement("div");
    answers.className = "answers";

    q.answers.forEach((ans, i) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "answer-btn";
      btn.innerHTML = `<span class="answer-num">${i + 1}</span>${ans}`;
      btn.addEventListener("click", () => {
        selectedAnswers[currentQuestionIndex] = String(i + 1);
        currentQuestionIndex++;
        renderCurrentQuestion();
      });
      answers.appendChild(btn);
    });

    const navRow = document.createElement("div");
    navRow.className = "nav-row";

    const backBtn = document.createElement("button");
    backBtn.type = "button";
    backBtn.className = "nav-btn secondary";
    backBtn.textContent = "戻る";
    backBtn.disabled = currentQuestionIndex === 0;
    backBtn.addEventListener("click", () => {
      if (currentQuestionIndex > 0) {
        currentQuestionIndex--;
        renderCurrentQuestion();
      }
    });

    navRow.appendChild(backBtn);

    panel.appendChild(progressWrap);
    panel.appendChild(title);
    panel.appendChild(answers);
    panel.appendChild(navRow);
    quizDiv.appendChild(panel);
  }

  function showResult() {
    const key = selectedAnswers.join("");
    const finalType = ANIMAL_TYPES[key] || defaultType;
    const adviceItems = buildAdvice();
    const article = getArticleData();

    quizDiv.innerHTML = "";

    resultCard.innerHTML = `
      <div class="result-badge">診断完了</div>
      <div class="result-name">${finalType.name}</div>
      <div class="result-desc">${finalType.description}</div>
    `;

    adviceList.innerHTML = "";
    adviceItems.forEach((tip) => {
      const li = document.createElement("li");
      li.textContent = tip;
      adviceList.appendChild(li);
    });

    articleLink.textContent = `👉 ${article.title}`;
    articleLink.href = article.url;
    articleNote.textContent = article.note;

    shareXBtn.onclick = () => {
      const shareText = getShareText(finalType);
      const shareUrl = window.location.href;
      const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;
      window.open(xUrl, "_blank", "noopener,noreferrer");
    };

    copyResultBtn.onclick = async () => {
      const text = `${getShareText(finalType)}\n${window.location.href}`;
      try {
        await navigator.clipboard.writeText(text);
        copyResultBtn.textContent = "コピーしました";
        setTimeout(() => {
          copyResultBtn.textContent = "結果文をコピー";
        }, 1600);
      } catch (e) {
        alert("コピーに失敗しました。");
      }
    };

    resultArea.classList.remove("hidden");
    resultArea.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  restartBtn.addEventListener("click", () => {
    currentQuestionIndex = 0;
    selectedAnswers = [];
    resultArea.classList.add("hidden");
    renderCurrentQuestion();
  });

  renderCurrentQuestion();
});
</script>
</body>
</html>
